{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"baseUrl": ".",
		"paths": {
			"#src/*": ["src/*"]
		},
		"allowImportingTsExtensions": true,
		"ignoreDeprecations": "6.0",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"useUnknownInCatchVariables": true
	},
	"include": ["scripts/**/*.ts", "src/**/*.ts"]
}